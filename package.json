{
  "name": "plumbline",
  "version": "0.1.0",
  "description": "Local first faithfulness engine for language model output. Verifies generated text against its sources claim by claim, with span level attribution and calibrated confidence.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "plumbline": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "faithfulness",
    "grounding",
    "hallucination",
    "rag",
    "nli",
    "verification"
  ],
  "optionalDependencies": {
    "@huggingface/transformers": "^3.8.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "esbuild": "0.21.5",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "overrides": {
    "esbuild": "0.21.5"
  }
}
